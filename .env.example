# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# Every path / tunable in the codebase is read from here. No hardcoded values.
# ---------------------------------------------------------------------------

# --- Storage --------------------------------------------------------------
# DuckDB file that holds raw benchmark output + dbt models.
DUCKDB_PATH=data/duckdb/benchmark.duckdb

# dlt landing zone (intermediate load packages).
DLT_DATA_DIR=data/raw

# --- Benchmark defaults ---------------------------------------------------
# Used when running the pipeline standalone (Dagster sweep overrides these).
BENCHMARK_TOTAL_ROWS=5000000
BENCHMARK_DEFAULT_BATCH_SIZE=10000
BENCHMARK_DEFAULT_ROW_WIDTH=medium
BENCHMARK_DEFAULT_COMPLEXITY=simple

# Batch sizes the sweep job iterates over (comma separated).
BENCHMARK_BATCH_SIZES=100,1000,5000,10000,50000,100000,500000,1000000

# Row-width variants the sweep iterates over (comma separated).
BENCHMARK_ROW_WIDTHS=narrow,medium,wide

# Repetitions per (batch_size, row_width) cell, for median statistics.
BENCHMARK_REPETITIONS=3

# --- Resource monitor -----------------------------------------------------
# psutil sampling interval, milliseconds.
MONITOR_SAMPLE_INTERVAL_MS=100

# --- Determinism ----------------------------------------------------------
# Seed for Faker so synthetic data is reproducible across runs.
FAKER_SEED=42

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO

# --- Dagster --------------------------------------------------------------
DAGSTER_HOME=/opt/dagster/dagster_home
